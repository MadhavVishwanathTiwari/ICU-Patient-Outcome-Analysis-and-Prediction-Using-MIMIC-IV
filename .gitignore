# Data files (DO NOT COMMIT RAW DATA)
mimic-iv-2.2/
mimic-iv-ed-2.2/
*.csv
*.csv.gz
*.zip
*.gz
data/raw/
!data/processed/.gitkeep
!data/interim/.gitkeep

# Models - Exclude large formats and SPECIFICALLY tuned models
*.h5
*.pt
models/*.h5
models/*.pt

# 1. Ignore all pickle files globally first
*.pkl

# 2. Allow pickle files inside the models/ directory
!models/*.pkl
!models/**/*.pkl

# 3. EXPLICITLY ignore everything in the tuned subdirectory 
# This overrides the allow rule above for this specific path
models/tuned/
models/tuned/**/*

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Reports (keep code, ignore large outputs)
reports/*.pdf
reports/figures/*.png
reports/figures/*.jpg

# Environment variables
.env
.env.local

# Temporary files
*.tmp
temp/
tmp/
